---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
import Viewer from '../components/Viewer.astro';

const {
  title = 'Santiago Creide · Desarrollador y técnico patagónico',
  description = 'Santiago Creide — desarrollador y técnico desde Neuquén, Patagonia. Automatización, sistemas de gestión y proyectos personales.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Santiago Creide" />
  <link rel="icon" type="image/png" href="/assets/logos/Fabicon.png" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:locale" content="es_AR" />
  <meta name="twitter:card" content="summary_large_image" />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
  <script is:inline>
    /* Evita el "flash": aplica el tema guardado antes de pintar. Default: oscuro. */
    (function () {
      try {
        var t = localStorage.getItem('tema');
        if (t === 'light' || t === 'dark') document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <div class="scroll-progress" id="scrollProgress"></div>
  <div class="cursor" id="cursor"></div>
  <div class="cursor-ring" id="cursorRing"></div>
  <Nav />
  <slot />
  <Footer />
  <ContactModal />
  <Viewer />
  <div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <span class="lightbox-close">[ esc ] cerrar</span>
    <img id="lightboxImg" src="" alt="" />
  </div>
  <script is:inline>
    /* ===== Cursor custom ===== */
    const cursor = document.getElementById('cursor'), ring = document.getElementById('cursorRing');
    let mx = 0, my = 0, rx = 0, ry = 0;
    document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; cursor.style.left = mx + 'px'; cursor.style.top = my + 'px'; });
    function animateRing(){ rx += (mx - rx) * .12; ry += (my - ry) * .12; ring.style.left = rx + 'px'; ring.style.top = ry + 'px'; requestAnimationFrame(animateRing); }
    animateRing();
    document.querySelectorAll('a,button,.granja-item').forEach(el => {
      el.addEventListener('mouseenter', () => { cursor.style.width = '16px'; cursor.style.height = '16px'; ring.style.width = '52px'; ring.style.height = '52px'; });
      el.addEventListener('mouseleave', () => { cursor.style.width = '8px'; cursor.style.height = '8px'; ring.style.width = '32px'; ring.style.height = '32px'; });
    });

    /* ===== Efectos de scroll (reveals, stagger, wipe, parallax, progreso, scroll-spy) ===== */
    (function(){
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Reveals: fade-up, stagger y wipe (con fallback si no hay IntersectionObserver)
      const revealEls = document.querySelectorAll('.reveal, .reveal-stagger, .reveal-wipe');
      if (!('IntersectionObserver' in window)) {
        revealEls.forEach(el => el.classList.add('visible'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (!e.isIntersecting) return;
            e.target.classList.add('visible');
            if (e.target.classList.contains('reveal-stagger')) {
              [...e.target.children].forEach((c, i) => { c.style.transitionDelay = (i * 0.08) + 's'; });
            }
            io.unobserve(e.target);
          });
        }, { threshold: .1 });
        revealEls.forEach(el => io.observe(el));
      }

      if (reduce) return; // sin parallax ni motion adicional

      // Barra de progreso de scroll
      const bar = document.getElementById('scrollProgress');
      // Scroll-spy
      const navLinks = new Map();
      document.querySelectorAll('.nav-links a[href^="#"]').forEach(a => navLinks.set(a.getAttribute('href').slice(1), a));
      const spy = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (!e.isIntersecting) return;
          navLinks.forEach(a => a.classList.remove('active'));
          const a = navLinks.get(e.target.id);
          if (a) a.classList.add('active');
        });
      }, { rootMargin: '-45% 0px -50% 0px' });
      document.querySelectorAll('section[id]').forEach(s => spy.observe(s));

      // Parallax + barra de progreso + hero que se despide (en un solo rAF)
      const hero = document.querySelector('.hero');
      const heroBg = document.querySelector('.hero-bg');
      const heroContent = document.querySelector('.hero-content');
      const parallaxEls = [...document.querySelectorAll('[data-parallax]')];
      let ticking = false;
      function onScroll(){
        const y = window.scrollY;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        if (bar) bar.style.width = (max > 0 ? (y / max) * 100 : 0) + '%';
        const hh = hero ? hero.offsetHeight : 0;
        if (y < hh + 100) {
          if (heroBg) heroBg.style.transform = 'translateY(' + (y * 0.35) + 'px)';
          if (heroContent) {
            heroContent.style.transform = 'translateY(' + (y * 0.18) + 'px)';
            heroContent.style.opacity = Math.max(0, 1 - y / (hh * 0.65));
          }
        }
        parallaxEls.forEach(el => {
          const r = el.getBoundingClientRect();
          const speed = parseFloat(el.dataset.parallax) || 0.08;
          const offset = r.top + r.height / 2 - window.innerHeight / 2;
          el.style.translate = '0 ' + (offset * -speed).toFixed(1) + 'px';
        });
        ticking = false;
      }
      window.addEventListener('scroll', () => { if (!ticking) { requestAnimationFrame(onScroll); ticking = true; } }, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      onScroll();
    })();

    /* ===== Smooth scroll para anclas ===== */
    document.querySelectorAll('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => { const t = document.querySelector(a.getAttribute('href')); if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); } });
    });

    /* ===== Lightbox (galería / capturas) ===== */
    function openLightbox(el){ document.getElementById('lightboxImg').src = el.querySelector('img').src; document.getElementById('lightbox').classList.add('active'); document.body.style.overflow = 'hidden'; }
    function closeLightbox(){ document.getElementById('lightbox').classList.remove('active'); document.body.style.overflow = ''; }
    document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

    /* ===== Toggle de tema ===== */
    (function () {
      const btn = document.getElementById('themeToggle');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('tema', next); } catch (e) {}
      });
    })();

    /* ===== i18n (ESP / ENG) =====
       Cada elemento traducible lleva data-en con su versión en inglés.
       El español es el contenido natural del elemento. */
    function curLang(){ return document.documentElement.getAttribute('lang') === 'en' ? 'en' : 'es'; }
    function L(es, en){ return curLang() === 'en' ? en : es; }
    function applyLang(lang){
      document.querySelectorAll('[data-en]').forEach(el => {
        if (el.dataset.es === undefined) el.dataset.es = el.innerHTML;
        el.innerHTML = (lang === 'en') ? el.dataset.en : el.dataset.es;
      });
      document.querySelectorAll('[data-en-ph]').forEach(el => {
        if (el.dataset.esPh === undefined) el.dataset.esPh = el.getAttribute('placeholder') || '';
        el.setAttribute('placeholder', (lang === 'en') ? el.dataset.enPh : el.dataset.esPh);
      });
      document.documentElement.setAttribute('lang', lang);
      const label = document.getElementById('langLabel');
      if (label) label.textContent = (lang === 'en') ? 'ENG' : 'ESP';
    }
    (function(){
      let lang = 'es';
      try { const s = localStorage.getItem('idioma'); if (s === 'en' || s === 'es') lang = s; } catch (e) {}
      applyLang(lang);
    })();
    (function(){
      const btn = document.getElementById('langToggle');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const next = curLang() === 'en' ? 'es' : 'en';
        applyLang(next);
        try { localStorage.setItem('idioma', next); } catch (e) {}
      });
    })();

    /* ===== Modal de consulta anónima ===== */
    const cModal = document.getElementById('contactModal');
    const cForm = document.getElementById('contactForm');
    const cMsg = document.getElementById('cf-msg');
    const cSubmit = document.getElementById('cf-submit');
    let cOpenedAt = 0, cExpected = 7;
    function openContactModal(){
      const a = Math.floor(Math.random() * 6) + 2, b = Math.floor(Math.random() * 6) + 2;
      cExpected = a + b;
      document.getElementById('cf-human-q').textContent = L('Verificación: ¿cuánto es ', 'Verification: what is ') + a + ' + ' + b + '?';
      document.getElementById('cf-human').value = '';
      setMsg('', 'hint');
      cModal.classList.add('active');
      document.body.style.overflow = 'hidden';
      cOpenedAt = Date.now();
      cSubmit.disabled = true;
      setTimeout(() => { cSubmit.disabled = false; }, 3000);
      setTimeout(() => document.getElementById('cf-nombre').focus(), 350);
    }
    function closeContactModal(){ cModal.classList.remove('active'); document.body.style.overflow = ''; }
    function setMsg(t, cls){ cMsg.className = 'modal-msg ' + (cls || 'hint'); cMsg.textContent = t; }
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && cModal.classList.contains('active')) closeContactModal(); });
    cForm.addEventListener('submit', async e => {
      e.preventDefault();
      const nombre = cForm.nombre.value.trim();
      const email = cForm.email.value.trim();
      const mensaje = cForm.mensaje.value.trim();
      const human = cForm.human.value.trim();
      const website = cForm.website.value;
      const elapsed = Date.now() - cOpenedAt;
      if (website) { closeContactModal(); return; }
      if (elapsed < 3000) { setMsg(L('Esperá un segundo antes de enviar.', 'Wait a second before sending.'), 'err'); return; }
      if (!nombre || !email || !mensaje) { setMsg(L('Completá nombre, email y mensaje.', 'Please fill in name, email and message.'), 'err'); return; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setMsg(L('El email no parece válido.', 'That email doesn\'t look valid.'), 'err'); return; }
      if (parseInt(human, 10) !== cExpected) { setMsg(L('La verificación es incorrecta. Probá de nuevo.', 'The verification is incorrect. Try again.'), 'err'); return; }
      cSubmit.disabled = true; setMsg(L('Enviando…', 'Sending…'), 'hint');
      try {
        const res = await fetch('/api/contact', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ nombre, email, mensaje, website, human, elapsed }) });
        if (res.ok) {
          setMsg(L('¡Listo! Tu consulta llegó. Te respondo pronto.', 'Done! Your message arrived. I\'ll get back to you soon.'), 'ok');
          cForm.reset();
          setTimeout(closeContactModal, 1800);
        } else {
          const data = await res.json().catch(() => ({}));
          setMsg(data.error || L('No se pudo enviar. Probá por mail: santi.creide@gmail.com', 'Couldn\'t send. Try email: santi.creide@gmail.com'), 'err');
          cSubmit.disabled = false;
        }
      } catch (err) {
        setMsg(L('No hay servidor de mensajes activo. Escribime a santi.creide@gmail.com', 'No message server active. Email me at santi.creide@gmail.com'), 'err');
        cSubmit.disabled = false;
      }
    });

    /* ===== Visor (certificados / CV / notas) ===== */
    const viewer = document.getElementById('viewer');
    const viewerBody = document.getElementById('viewerBody');
    const viewerTitle = document.getElementById('viewerTitle');
    function showViewer(){ viewer.classList.add('active'); document.body.style.overflow = 'hidden'; }
    function closeViewer(){ viewer.classList.remove('active'); document.body.style.overflow = ''; setTimeout(() => { viewerBody.innerHTML = ''; viewerBody.className = 'viewer-body'; }, 350); }
    function openFrame(src, title, isPdf){
      viewerTitle.textContent = title;
      const url = isPdf ? src + '#toolbar=0&navpanes=0&scrollbar=0&view=FitH' : src;
      viewerBody.className = 'viewer-body protected';
      const f = document.createElement('iframe');
      f.src = url; f.title = title;
      viewerBody.innerHTML = ''; viewerBody.appendChild(f);
      showViewer();
    }
    function openNote(id, title){
      const s = document.getElementById(id); if (!s) return;
      const h = s.querySelector('h2');
      viewerTitle.textContent = title || (h ? h.textContent : 'Nota');
      viewerBody.className = 'viewer-body';
      viewerBody.innerHTML = '<article class="viewer-prose">' + s.innerHTML + '</article>';
      viewerBody.scrollTop = 0;
      showViewer();
    }
    function openImage(src, title){
      viewerTitle.textContent = title;
      viewerBody.className = 'viewer-body protected viewer-imgwrap';
      const img = document.createElement('img');
      img.src = src; img.alt = title; img.className = 'viewer-img'; img.draggable = false;
      viewerBody.innerHTML = ''; viewerBody.appendChild(img);
      showViewer();
    }
    viewerBody.addEventListener('contextmenu', e => { if (viewerBody.classList.contains('protected')) e.preventDefault(); });
    viewerBody.addEventListener('dragstart', e => { if (viewerBody.classList.contains('protected')) e.preventDefault(); });
    document.addEventListener('keydown', e => { if (e.key === 'Escape' && viewer.classList.contains('active')) closeViewer(); });
    document.querySelectorAll('.cert-card').forEach(a => {
      const href = a.getAttribute('href') || '';
      const lower = href.toLowerCase();
      const isPdf = lower.endsWith('.pdf');
      const isImg = /\.(png|jpe?g|webp|gif)$/.test(lower);
      if (isPdf || isImg) {
        a.addEventListener('click', e => {
          e.preventDefault();
          const issuer = a.querySelector('.cert-issuer');
          const name = a.querySelector('.cert-name');
          const title = ((issuer ? issuer.textContent + ' · ' : '') + (name ? name.textContent : 'Certificado'));
          if (isPdf) openFrame(href, title, true);
          else openImage(href, title);
        });
      }
    });
  </script>
</body>
</html>
