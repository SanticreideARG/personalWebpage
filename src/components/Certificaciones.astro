---
import { certificados } from '../data/certificados.js';
---
<section class="certificaciones" id="certificaciones">
  <div class="s-eyebrow reveal" data-en="Certifications">Certificaciones</div>
  <h2 class="s-title reveal" data-en="Papers that back up the <em>journey.</em>">Papeles que respaldan el <em>camino.</em></h2>
  <div class="cert-grid reveal-stagger">
    {certificados.map((c) => (
      <a href={c.href} target="_blank" class="cert-card">
        <div class="cert-issuer">{c.issuer}</div>
        <div class="cert-name" data-en={c.name_en}>{c.name}</div>
        <div class="cert-meta"><span data-en={c.meta_en}>{c.meta}</span><span class="cert-open" data-en={c.action_en}>{c.action}</span></div>
      </a>
    ))}
  </div>
</section>
