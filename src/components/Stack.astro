---
const cols = [
  { title: 'Backend', items: ['Laravel 11', 'PHP 8.3', 'Filament 3', 'Livewire', 'Node.js', 'Express.js'] },
  { title: 'Frontend', items: ['Alpine.js', 'Tailwind CSS', 'React', 'JavaScript', 'HTML5 · CSS3'] },
  { title: 'Data & Automation', items: ['MySQL', 'PostgreSQL', 'SQL Server', 'MongoDB', 'n8n', 'Redis'] },
  { title: 'Infra & DevOps', items: ['Docker', 'Linux · Ubuntu', 'Windows Server', 'NGINX', 'MTCNA · Redes', 'GitHub Actions'] },
];
---
<section class="stack-section" id="stack">
  <div class="s-eyebrow reveal" data-en="Tech stack">Stack tecnológico</div>
  <h2 class="s-title reveal" data-en="The tools of the <em>trade.</em>">Las herramientas del <em>oficio.</em></h2>
  <div class="stack-cols reveal">
    {cols.map((c) => (
      <div class="stack-col">
        <div class="stack-col-title">{c.title}</div>
        {c.items.map((i) => (
          <div class="stack-item"><span class="stack-dot"></span>{i}</div>
        ))}
      </div>
    ))}
  </div>
</section>
