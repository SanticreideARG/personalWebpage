---
import { notas } from '../data/notas.js';
---
<section class="notas" id="notas">
  <div class="s-eyebrow reveal" data-en="Notes">Notas</div>
  <h2 class="s-title reveal" data-en="Things I'm <em>learning.</em>">Cosas que <em>voy aprendiendo.</em></h2>
  <p class="s-body reveal" data-en="Loose notes on what I build, break and put back together. No tutorial pretensions — more of a public notebook.">Apuntes sueltos sobre lo que construyo, rompo y vuelvo a armar. Sin pretensión de tutorial — más bien un cuaderno público.</p>
  <div class="notas-grid reveal">
    {notas.map((n) => (
      <a href="#" class="nota-card" onclick={`openNote('${n.id}');return false;`}>
        <div class="nota-date" data-en={n.label_en}>{n.label}</div>
        <h4 data-en={n.title_en}>{n.title}</h4>
        <p data-en={n.excerpt_en}>{n.excerpt}</p>
        <span class="nota-more" data-en="read →">leer →</span>
      </a>
    ))}
  </div>
  <p class="notas-soon reveal" data-en="I'm writing these little by little — tap any of them to read it in full.">Estas notas las voy escribiendo de a poco — tocá cualquiera para leerla completa.</p>

  <div id="notas-sources" style="display:none">
    {notas.map((n) => (
      <div id={n.id}>
        <div class="vp-meta" data-en={n.meta_en}>{n.meta}</div>
        <h2 data-en={n.title_en}>{n.title}</h2>
        <div class="nota-body" data-en={n.body_en} set:html={n.body}></div>
      </div>
    ))}
  </div>
</section>
